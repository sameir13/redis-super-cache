{
  "name": "redis-super-cache",
  "version": "1.0.0",
  "description": "Production-grade Redis caching with fflate compression, tag invalidation, pipelines, warmup, and Prometheus metrics",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:clean": "rimraf dist && npm run build",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "prepublishOnly": "npm run build:clean && npm run test"
  },
  "keywords": ["redis", "cache", "fflate", "compression", "prometheus", "metrics", "warmup"],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "prom-client": "^15.1.0",
    "redis": "^4.6.0",
    "xxhashjs": "^0.2.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/xxhashjs": "^0.2.4",
    "jest": "^29.5.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.1.0"
  }
}